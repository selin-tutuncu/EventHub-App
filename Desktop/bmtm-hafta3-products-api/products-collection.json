  "item": [
    {
      "name": "8. POST /auth/login (başarılı)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Yanıtı JSON formatında alalım\r",
              "const res = pm.response.json();\r",
              "\r",
              "// 2. TOKEN CHAINING: Gelen accessToken'ı \"authToken\" değişkenine kaydet\r",
              "// Bu adım ödevin en kritik ve zorunlu kısmıdır!\r",
              "pm.environment.set(\"authToken\", res.accessToken);\r",
              "\r",
              "// 3. Hocanın istediği Assertion'lar (Doğrulamalar)\r",
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Token is returned and valid\", () => {\r",
              "    pm.expect(res.accessToken).to.not.be.undefined;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET /products (Zorunlu JSON Schema)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"required\": [\"products\", \"total\", \"skip\", \"limit\"],\r",
              "    \"properties\": {\r",
              "        \"products\": {\r",
              "            \"type\": \"array\",\r",
              "            \"items\": {\r",
              "                \"type\": \"object\",\r",
              "                \"required\": [\"id\", \"title\", \"price\", \"category\", \"thumbnail\"]\r",
              "            }\r",
              "        }\r",
              "    }\r",
              "};\r",
              "pm.test(\"Status code is 200\", () => { pm.response.to.have.status(200); });\r",
              "pm.test(\"JSON Schema is valid\", () => { pm.response.to.have.jsonSchema(schema); });\r",
              "pm.test(\"Response time < 2s\", () => { pm.expect(pm.response.responseTime).to.be.below(2000); });\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products?limit=5&skip=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "limit",
              "value": "5"
            },
            {
              "key": "skip",
              "value": "5"
            }
          ]
        }
      },
      "response": []
    },
