    {
      "name": "POST /products/add (Zorunlu Pre-request Script)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const brands = [\"Apple\", \"Samsung\", \"Sony\"];\r",
              "const randomBrand = brands[Math.floor(Math.random() * brands.length)];\r",
              "const randomPrice = Math.floor(Math.random() * 5000) + 100;\r",
              "pm.environment.set(\"randomBrand\", randomBrand);\r",
              "pm.environment.set(\"randomPrice\", randomPrice);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{ \"title\": \"Selin Test Ürünü\", \"price\": {{randomPrice}}, \"brand\": \"{{randomBrand}}\", \"category\": \"smartphones\" }\r\n\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/products/add",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "add"
          ]
        }
      },
      "response": []
