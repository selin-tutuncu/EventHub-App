@model EventHub.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Giris Yap";
    Layout = "_Layout";
}

<section style="min-height:calc(100vh - 80px);display:flex;align-items:center;background:var(--gradient-hero);padding:3rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">

                <!-- Giris Karti -->
                <div class="card-base animate-on-scroll" style="padding:2.5rem;">

                    <!-- Baslik -->
                    <div class="text-center mb-2">
                        <div style="width:56px;height:56px;background:var(--gradient-brand);border-radius:var(--border-radius-md);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;">
                            <i class="bi bi-calendar-event-fill" style="color:white;"></i>
                        </div>
                        <h1 style="font-family:'Fraunces',serif;font-size:1.8rem;font-weight:600;margin-bottom:0.3rem;color:var(--text-primary);">
                            Tekrar Hosgeldiniz
                        </h1>
                        <p style="color:var(--text-muted);font-size:0.9rem;">
                            Hesabiniza giris yapin
                        </p>
                    </div>

                    <div class="divider"></div>

                    <!-- Demo Bilgi Kutusu -->
                    <div class="alert-custom alert-info mb-4" style="font-size:0.82rem;">
                        <span class="alert-icon"><i class="bi bi-info-circle"></i></span>
                        <div>
                            <strong>Demo Hesabi:</strong><br />
                            Admin: admin@eventhub.com / Admin123!
                        </div>
                    </div>

                    <!-- Giris Formu -->
                    <form asp-action="Login" asp-controller="Account" method="post" data-loading="true">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                        <!-- E-posta -->
                        <div class="form-group">
                            <label asp-for="Email" class="form-label-custom"></label>
                            <div style="position:relative;">
                                <i class="bi bi-envelope" style="position:absolute;left:0.9rem;top:50%;transform:translateY(-50%);color:var(--text-muted);"></i>
                                <input asp-for="Email" class="form-control-custom" type="email"
                                       placeholder="ornek@email.com"
                                       style="padding-left:2.5rem;" />
                            </div>
                            <span asp-validation-for="Email" class="field-validation-error"></span>
                        </div>

                        <!-- Sifre -->
                        <div class="form-group">
                            <label asp-for="Password" class="form-label-custom"></label>
                            <div style="position:relative;">
                                <i class="bi bi-lock" style="position:absolute;left:0.9rem;top:50%;transform:translateY(-50%);color:var(--text-muted);"></i>
                                <input asp-for="Password" class="form-control-custom" type="password"
                                       placeholder="Sifreniz"
                                       style="padding-left:2.5rem;padding-right:2.5rem;"
                                       id="passwordInput" />
                                <button type="button" onclick="togglePasswordVisibility()"
                                        style="position:absolute;right:0.9rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0;">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-validation-error"></span>
                        </div>

                        <!-- Beni Hatirla -->
                        <div class="form-group d-flex align-items-center justify-content-between">
                            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);">
                                <input asp-for="RememberMe" type="checkbox"
                                       style="width:16px;height:16px;accent-color:var(--color-brand);" />
                                Beni Hatirla
                            </label>
                            <a href="#" style="font-size:0.85rem;color:var(--color-brand);">Sifremi Unuttum</a>
                        </div>

                        <!-- Giris Butonu -->
                        <button type="submit" class="btn-brand w-100" style="justify-content:center;">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Giris Yap
                        </button>

                    </form>

                    <div class="divider"></div>

                    <!-- Kayit Yonlendirme -->
                    <p style="text-align:center;font-size:0.88rem;color:var(--text-muted);margin:0;">
                        Hesabiniz yok mu?
                        <a asp-controller="Account" asp-action="Register" style="font-weight:600;">
                            Ucretsiz Kayit Ol
                        </a>
                    </p>

                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Sifre goster/gizle
        function togglePasswordVisibility() {
            var input = document.getElementById('passwordInput');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
