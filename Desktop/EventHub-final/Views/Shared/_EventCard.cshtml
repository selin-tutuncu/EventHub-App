@* 
    _EventCard.cshtml - Etkinlik Karti Partial View
    Kullanim: @await Html.PartialAsync("_EventCard", model)
    Parametre: EventListItemViewModel
*@
@model EventHub.ViewModels.EventListItemViewModel
@using EventHub.Models

@{
    // Kapasite yuzdesi hesaplama
    var capacityPercent = Model.MaxCapacity > 0
        ? Math.Min(100, (int)((double)Model.CurrentParticipantCount / Model.MaxCapacity * 100))
        : 0;

    // Kategori Turkce adi
    var categoryDisplay = Model.Category switch
    {
        EventCategory.Workshop => "Workshop",
        EventCategory.Conference => "Konferans",
        EventCategory.Seminar => "Seminer",
        EventCategory.Networking => "Networking",
        EventCategory.Hackathon => "Hackathon",
        EventCategory.Training => "Egitim",
        EventCategory.Concert => "Konser",
        EventCategory.Cinema => "Sinema",
        EventCategory.Theater => "Tiyatro",
        EventCategory.Sports => "Spor",
        EventCategory.Festival => "Festival",
        EventCategory.Exhibition => "Sergi",
        EventCategory.SeminarSeries => "Seminer Serisi",
        _ => "Diger"
    };
}

<div class="event-card animate-on-scroll">

    <!-- Etkinlik Kapaği Gorseli -->
    <div class="event-card-image">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" alt="@Model.Title" loading="lazy" />
        }
        else
        {
            <!-- Gorsel yoksa kategori renginde arka plan -->
            <div class="event-card-image-placeholder">
                @switch (Model.Category)
                {
                    case EventCategory.Workshop:
                        <i class="bi bi-hammer"></i>
                        break;
                    case EventCategory.Conference:
                        <i class="bi bi-mic"></i>
                        break;
                    case EventCategory.Seminar:
                        <i class="bi bi-journal-text"></i>
                        break;
                    case EventCategory.Networking:
                        <i class="bi bi-people"></i>
                        break;
                    case EventCategory.Hackathon:
                        <i class="bi bi-code-slash"></i>
                        break;
                    case EventCategory.Training:
                        <i class="bi bi-mortarboard"></i>
                        break;
                    case EventCategory.Concert:
                        <i class="bi bi-music-note-beamed"></i>
                        break;
                    case EventCategory.Cinema:
                        <i class="bi bi-film"></i>
                        break;
                    case EventCategory.Theater:
                        <i class="bi bi-ticket-perforated"></i>
                        break;
                    case EventCategory.Sports:
                        <i class="bi bi-trophy"></i>
                        break;
                    case EventCategory.Festival:
                        <i class="bi bi-stars"></i>
                        break;
                    case EventCategory.Exhibition:
                        <i class="bi bi-palette"></i>
                        break;
                    case EventCategory.SeminarSeries:
                        <i class="bi bi-journal-richtext"></i>
                        break;
                    default:
                        <i class="bi bi-calendar-event"></i>
                        break;
                }
            </div>
        }
    </div>

    <!-- Kart Govdesi -->
    <div class="event-card-body">

        <!-- Kategori Etiketi -->
        <div class="event-card-category">
            @categoryDisplay
        </div>

        <!-- Etkinlik Basligi -->
        <h3 class="event-card-title">@Model.Title</h3>

        @if (!string.IsNullOrWhiteSpace(Model.Summary))
        {
            <p class="event-card-summary">
                @(Model.Summary.Length > 120 ? Model.Summary.Substring(0, 120) + "..." : Model.Summary)
            </p>
        }

        <!-- Meta Bilgiler -->
        <div class="event-card-meta">
            <div class="event-meta-item">
                <i class="bi bi-calendar3"></i>
                <span>@Model.EventDate.ToString("dd MMMM yyyy, HH:mm", new System.Globalization.CultureInfo("tr-TR"))</span>
            </div>
            <div class="event-meta-item">
                <i class="bi bi-geo-alt"></i>
                <span>@(Model.Location.Length > 40 ? Model.Location.Substring(0, 40) + "..." : Model.Location)</span>
            </div>
            <div class="event-meta-item">
                <i class="bi bi-person"></i>
                <span>@Model.OrganizerName</span>
            </div>
        </div>

        <!-- Kontenjan Durumu (kontenjan tanimlanmissa) -->
        @if (Model.MaxCapacity > 0)
        {
            <div>
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span style="font-size:0.78rem;color:var(--text-muted);font-weight:600;">
                        Kontenjan
                    </span>
                    <span style="font-size:0.78rem;color:var(--text-muted);">
                        @Model.CurrentParticipantCount / @Model.MaxCapacity
                    </span>
                </div>
                <div class="capacity-bar">
                    <div class="capacity-bar-fill @(Model.IsFullyBooked ? "full" : "")"
                         style="width: @capacityPercent%"></div>
                </div>
            </div>
        }

    </div>

    <!-- Kart Alt Kismi -->
    <div class="event-card-footer">
        <div class="d-flex align-items-center gap-2 flex-wrap">

            <!-- Ucretsiz / Ucret -->
            @if (Model.IsPaid)
            {
                <span class="badge-paid">@Model.Price.ToString("N0") TL</span>
            }
            else
            {
                <span style="font-size:0.78rem;font-weight:700;color:var(--color-success);">
                    Ucretsiz
                </span>
            }

            <!-- Dolu Rozeti -->
            @if (Model.IsFullyBooked)
            {
                <span class="badge-full">Dolu</span>
            }

            <!-- Kayitliyim Rozeti -->
            @if (Model.IsRegistered)
            {
                <span class="badge-registered">
                    <i class="bi bi-check-circle-fill"></i> Kayitliyim
                </span>
            }
            @if (Model.IsWaitlisted)
            {
                <span class="status-badge status-draft">
                    <i class="bi bi-hourglass-split"></i> Beklemede
                </span>
            }
        </div>

        <!-- Detay Butonu -->
        <a asp-controller="Event" asp-action="Detail" asp-route-id="@Model.Id"
           class="btn-brand btn-sm">
            Detay
            <i class="bi bi-arrow-right"></i>
        </a>
    </div>

</div>
