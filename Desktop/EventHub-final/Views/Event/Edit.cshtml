@model EventHub.ViewModels.EventFormViewModel
@using EventHub.Models
@{
    ViewData["Title"] = "Etkinlik Duzenle";
}

<!-- Sayfa Basligi -->
<div class="page-header">
    <div class="container">
        <ul class="breadcrumb-custom">
            <li><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
            <li><a asp-controller="Admin" asp-action="Events">Admin - Etkinlikler</a></li>
            <li>Etkinlik Duzenle</li>
        </ul>
        <h1 class="page-header-title">Etkinlik Duzenle</h1>
        <p class="page-header-subtitle">Etkinlik bilgilerini guncelleyin.</p>
    </div>
</div>

<section class="section-gap-sm">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <form asp-action="Edit" asp-controller="Event" method="post" data-loading="true" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <!-- ID gizli alan olarak tasınir -->
                    <input asp-for="Id" type="hidden" />

                    <!-- Validasyon ozeti -->
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                    <!-- TEMEL BILGILER -->
                    <div class="card-base mb-4 animate-on-scroll">
                        <h5 style="font-weight:700;color:var(--text-primary);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.5rem;">
                            <span style="width:28px;height:28px;background:var(--gradient-brand);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:white;font-size:0.8rem;font-weight:800;flex-shrink:0;">1</span>
                            Temel Bilgiler
                        </h5>

                        <div class="form-group">
                            <label asp-for="Title" class="form-label-custom"></label>
                            <input asp-for="Title" class="form-control-custom" />
                            <span asp-validation-for="Title" class="field-validation-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Summary" class="form-label-custom"></label>
                            <input asp-for="Summary" class="form-control-custom" />
                            <span asp-validation-for="Summary" class="field-validation-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="form-label-custom"></label>
                            <textarea asp-for="Description" class="form-control-custom" rows="7" style="resize:vertical;"></textarea>
                            <span asp-validation-for="Description" class="field-validation-error"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group mb-0">
                                    <label asp-for="Category" class="form-label-custom"></label>
                                    <select asp-for="Category" class="form-control-custom"
                                            asp-items="Html.GetEnumSelectList<EventCategory>()"></select>
                                    <span asp-validation-for="Category" class="field-validation-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-0">
                                    <label asp-for="Status" class="form-label-custom"></label>
                                    <select asp-for="Status" class="form-control-custom"
                                            asp-items="Html.GetEnumSelectList<EventStatus>()"></select>
                                    <span asp-validation-for="Status" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- TARIH VE KONUM -->
                    <div class="card-base mb-4 animate-on-scroll delay-100">
                        <h5 style="font-weight:700;color:var(--text-primary);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.5rem;">
                            <span style="width:28px;height:28px;background:var(--gradient-brand);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:white;font-size:0.8rem;font-weight:800;flex-shrink:0;">2</span>
                            Tarih, Saat ve Konum
                        </h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="EventDate" class="form-label-custom"></label>
                                    <input asp-for="EventDate" type="datetime-local"
                                           asp-format="{0:yyyy-MM-ddTHH:mm}"
                                           class="form-control-custom" />
                                    <span asp-validation-for="EventDate" class="field-validation-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="EndDate" class="form-label-custom"></label>
                                    <input asp-for="EndDate" type="datetime-local"
                                           asp-format="{0:yyyy-MM-ddTHH:mm}"
                                           class="form-control-custom" />
                                    <span asp-validation-for="EndDate" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Location" class="form-label-custom"></label>
                            <input asp-for="Location" class="form-control-custom" />
                            <span asp-validation-for="Location" class="field-validation-error"></span>
                        </div>

                        <div class="form-group mb-0">
                            <label asp-for="OnlineUrl" class="form-label-custom"></label>
                            <input asp-for="OnlineUrl" class="form-control-custom"
                                   placeholder="https://..." />
                            <span asp-validation-for="OnlineUrl" class="field-validation-error"></span>
                        </div>
                    </div>

                    <!-- KONTENJAN VE UCRET -->
                    <div class="card-base mb-4 animate-on-scroll delay-200">
                        <h5 style="font-weight:700;color:var(--text-primary);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.5rem;">
                            <span style="width:28px;height:28px;background:var(--gradient-brand);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:white;font-size:0.8rem;font-weight:800;flex-shrink:0;">3</span>
                            Kontenjan ve Ucret
                        </h5>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-group mb-0">
                                    <label asp-for="MaxCapacity" class="form-label-custom"></label>
                                    <input asp-for="MaxCapacity" type="number" min="0" class="form-control-custom" />
                                    <span asp-validation-for="MaxCapacity" class="field-validation-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-0">
                                    <label asp-for="CoverImageUrl" class="form-label-custom"></label>
                                    <input asp-for="CoverImageUrl" class="form-control-custom" />
                                    <small style="color:var(--text-muted);font-size:0.78rem;">URL kullanabilir ya da yeni dosya yukleyebilirsin.</small>
                                    @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                                    {
                                        <div class="profile-preview-card" style="margin-top:0.75rem;">
                                            <img src="@Model.CoverImageUrl" alt="@Model.Title" />
                                            <div>
                                                <strong>Mevcut kapak gorseli</strong>
                                                <p>Yeni bir dosya secersen bunun yerini alir.</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-0">
                                    <label asp-for="CoverImageFile" class="form-label-custom"></label>
                                    <input asp-for="CoverImageFile" class="form-control-custom" type="file" accept="image/*" />
                                    <span asp-validation-for="CoverImageFile" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="divider"></div>

                        <div class="form-group">
                            <label class="form-label-custom">
                                <input asp-for="IsPaid" type="checkbox" id="isPaidToggleEdit" />
                                Ucretli Etkinlik
                            </label>
                        </div>

                        <div id="priceGroupEdit" style="display:@(Model.IsPaid ? "block" : "none");">
                            <div class="form-group mb-0">
                                <label asp-for="Price" class="form-label-custom"></label>
                                <input asp-for="Price" type="number" min="0" step="0.01" class="form-control-custom" />
                                <span asp-validation-for="Price" class="field-validation-error"></span>
                            </div>
                        </div>
                    </div>

                    <!-- AKSIYONLAR -->
                    <div class="d-flex gap-3 justify-content-between animate-on-scroll delay-300">
                        <a asp-controller="Event" asp-action="Detail" asp-route-id="@Model.Id" class="btn-ghost">
                            <i class="bi bi-eye"></i> Detaya Don
                        </a>
                        <div class="d-flex gap-3">
                            <a asp-controller="Admin" asp-action="Events" class="btn-ghost">
                                <i class="bi bi-x-circle"></i> Vazgec
                            </a>
                            <button type="submit" class="btn-brand">
                                <i class="bi bi-check-circle"></i> Degisiklikleri Kaydet
                            </button>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var cb = document.getElementById('isPaidToggleEdit');
        var pg = document.getElementById('priceGroupEdit');
        if (cb) cb.addEventListener('change', function () {
            pg.style.display = this.checked ? 'block' : 'none';
        });
    </script>
}
